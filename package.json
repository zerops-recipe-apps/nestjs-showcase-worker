{
  "name": "nestjs-showcase-worker",
  "version": "0.1.0",
  "description": "NestJS standalone worker for the nestjs-showcase recipe — NATS subject subscriber, postgres/valkey/meilisearch/object-storage consumer.",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "migrate": "node dist/migrate.js",
    "migrate:dev": "ts-node src/migrate.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/typeorm": "^11.0.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "ioredis": "^5.4.1",
    "meilisearch": "^0.49.0",
    "nats": "^2.29.0",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@types/node": "^22.10.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
